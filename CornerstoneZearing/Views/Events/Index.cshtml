@{
    ViewData["Title"] = "Events";
}

<section class="events-page">
    <h1>Events</h1>
    <div id="calendar"></div>
</section>

<div class="modal fade" id="eventModal" tabindex="-1" aria-labelledby="eventModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="eventModalTitle">Event Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <h4 id="modal-event-name" class="mb-1"></h4>
                <p id="modal-event-date" class="text-muted mb-3"></p>
                <p id="modal-event-location" class="mb-2" style="display:none">
                    <strong>Location:</strong> <span id="modal-location-text"></span>
                </p>
                <p id="modal-event-description" style="display:none; white-space:pre-wrap"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        .events-page {
            max-width: 960px;
            margin: 2rem auto;
            padding: 0 1rem;
        }
        .events-page h1 {
            margin-bottom: 1.5rem;
        }
        #calendar {
            background: #fff;
        }
        /* Keep Bootstrap modal styles from conflicting with the site's nav/layout */
        .modal-backdrop {
            z-index: 1040;
        }
        .modal {
            z-index: 1050;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmBXKXHPvJQTijLgvqgzOPHIms1" crossorigin="anonymous"></script>
    <script>
    (function () {
        var eventModal = null;

        function formatEventDate(event) {
            var start = event.start;
            var end = event.end;
            var allDay = event.allDay;

            if (allDay) {
                var startStr = start.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                // FullCalendar all-day end is exclusive, so subtract one day for display
                if (end && end.getTime() - start.getTime() > 86400000) {
                    var displayEnd = new Date(end.getTime() - 86400000);
                    return startStr + '–' + displayEnd.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                }
                return startStr;
            }

            var dateOpts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            var timeOpts = { hour: 'numeric', minute: '2-digit' };
            var result = start.toLocaleDateString(undefined, dateOpts) + ', ' + start.toLocaleTimeString(undefined, timeOpts);
            if (end) {
                result += '–' + end.toLocaleTimeString(undefined, timeOpts);
            }
            return result;
        }

        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,listMonth'
                },
                events: '/Events/GetEvents',
                eventClick: function (info) {
                    var event = info.event;
                    var props = event.extendedProps;

                    document.getElementById('modal-event-name').textContent = event.title;
                    document.getElementById('modal-event-date').textContent = formatEventDate(event);

                    var locationEl = document.getElementById('modal-event-location');
                    if (props.location) {
                        document.getElementById('modal-location-text').textContent = props.location;
                        locationEl.style.display = 'block';
                    } else {
                        locationEl.style.display = 'none';
                    }

                    var descEl = document.getElementById('modal-event-description');
                    if (props.description) {
                        descEl.textContent = props.description;
                        descEl.style.display = 'block';
                    } else {
                        descEl.style.display = 'none';
                    }

                    if (!eventModal) {
                        eventModal = new bootstrap.Modal(document.getElementById('eventModal'));
                    }
                    eventModal.show();
                }
            });

            calendar.render();
        });
    }());
    </script>
}
