@model UserFormViewModel
@{
    var isEdit = Model.IsEdit;
    ViewData["Section"] = "Users";
    ViewData["Title"] = isEdit ? "Edit User" : "Add User";
}

<div class="page-header">
    <h1>@(isEdit ? "Edit User" : "Add User")</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="card" style="max-width:640px;">
    <div class="card-body">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @if (isEdit)
            {
                <input asp-for="UserID" type="hidden" />
            }
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Password">@(isEdit ? "New Password" : "Password")</label>
                    <input asp-for="Password" class="form-control" type="password"
                           placeholder="@(isEdit ? "Leave blank to keep current" : "")" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword">@(isEdit ? "Confirm New Password" : "Confirm Password")</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password"
                           placeholder="@(isEdit ? "Leave blank to keep current" : "")" />
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label>Roles</label>
                <div class="checkbox-grid">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <label class="form-check">
                            <input type="checkbox" name="SelectedRoles" value="@role"
                                   @(Model.SelectedRoles.Contains(role) ? "checked" : "") />
                            @role
                        </label>
                    }
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    @if (isEdit)
                    {
                        <i class="fas fa-floppy-disk"></i>
                        <span>Save Changes</span>
                    }
                    else
                    {
                        <i class="fas fa-user-plus"></i>
                        <span>Create User</span>
                    }
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
