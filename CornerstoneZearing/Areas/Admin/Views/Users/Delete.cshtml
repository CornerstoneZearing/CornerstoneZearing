@model UserListItemViewModel
@{
    ViewData["Section"] = "Users";
    ViewData["Title"] = "Delete User";
}

<div class="page-header">
    <h1>Delete User</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="card" style="max-width:520px;">
    <div class="card-body">
        <p style="font-size:.95rem;color:#475569;margin-bottom:1.25rem;">
            Are you sure you want to permanently delete this user? This action cannot be undone.
        </p>
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:1rem;margin-bottom:1.5rem;">
            <div style="font-weight:600;">@Model.DisplayName</div>
            <div class="text-muted">@Model.Email</div>
            @if (Model.Roles.Any())
            {
                <div style="margin-top:.5rem;">
                    @foreach (var role in Model.Roles)
                    {
                        <span class="badge badge-secondary">@role</span>
                        @(" ")
                    }
                </div>
            }
        </div>
        <div class="form-actions">
            <form asp-action="Delete" asp-route-id="@Model.UserID" method="post">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Yes, Delete User
                </button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</div>
