@model IEnumerable<UserListModel>
@{
	ViewData["Section"] = "Users";
	ViewData["Title"] = "Users";
}

<div class="page-header">
	<h1>Users</h1>
	<a asp-action="Create" class="btn btn-primary">
		<i class="fas fa-plus"></i> Add User
	</a>
</div>

<div class="card">
	<div class="table-wrapper">
		<table>
			<thead>
				<tr>
					<th style="width: 40%">Name</th>
					<th style="width: 40%">Email</th>
					<th style="width: 20%">Roles</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var user in Model)
				{
					<tr>
						<td><strong>@user.DisplayName</strong></td>
						<td class="text-muted">@user.Email</td>
						<td>
							@foreach (var role in user.Roles)
							{
								if (role == "Administrator")
								{
									<span class="badge badge-danger">
										@role
									</span>
								}
								else if (role == "Editor")
								{
									<span class="badge badge-success">
										@role
									</span>
								}
								else
								{
									<span class="badge badge-primary">
										@role
									</span>
								}
							}
						</td>
						<td>
							<div class="action-buttons">
								<a asp-action="Edit" asp-route-id="@user.UserID" class="btn btn-secondary btn-sm">
									<i class="fas fa-pen"></i> Edit
								</a>
								<a asp-action="Delete" asp-route-id="@user.UserID" class="btn btn-secondary btn-sm">
									<i class="fas fa-trash"></i>
								</a>
							</div>
						</td>
					</tr>
				}
				@if (!Model.Any())
				{
					<tr>
						<td colspan="4" style="text-align:center;color:#64748b;padding:2rem;">
							No users found.
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>