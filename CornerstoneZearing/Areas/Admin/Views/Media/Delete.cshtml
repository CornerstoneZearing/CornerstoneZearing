@model CornerstoneZearing.Data.MediaImage
@{
    ViewData["Section"] = "Media";
    ViewData["Title"] = "Delete Image";
}

<div class="page-header">
    <h1>Delete Image</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="card" style="max-width:520px;">
    <div class="card-body">
        <p style="font-size:.95rem;color:#475569;margin-bottom:1.25rem;">
            Are you sure you want to permanently delete this image? This action cannot be undone.
        </p>
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:1rem;margin-bottom:1.5rem;">
            <div style="display:flex;gap:1rem;align-items:flex-start;">
                <img src="/uploads/@Model.StoredFileName" alt="@Model.AltText"
                     style="width:80px;height:80px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;flex-shrink:0;" />
                <div>
                    <div style="font-weight:600;margin-bottom:.25rem;">@Model.OriginalFileName</div>
                    <div class="text-muted">@Model.ContentType</div>
                    <div class="text-muted">@((Model.FileSize / 1024.0).ToString("F1")) KB</div>
                    <div class="text-muted">@Model.DateUploaded.ToLocalTime().ToString("MMM d, yyyy")</div>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <form asp-action="Delete" asp-route-id="@Model.MediaImageID" method="post">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Yes, Delete Image
                </button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</div>
