@model PageFormModel
@{
    var isEdit = Model.PageID != Guid.Empty;
    ViewData["Section"] = "Pages";
    ViewData["Title"] = isEdit ? "Edit Page" : "Add Page";
}

<div class="page-header">
    <h1>@(isEdit ? "Edit Page" : "Add Page")</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
    @if (isEdit)
    {
        <input asp-for="PageID" type="hidden" />
    }
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div style="display:grid;grid-template-columns:1fr 320px;gap:1.25rem;align-items:start;">
        <div>
            <div class="card" style="margin-bottom:1.25rem;">
                <div class="card-header">Page Content</div>
                <div class="card-body">
                    <div class="form-group">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" class="form-control" id="pageName" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Content"></label>
                        <textarea asp-for="Content" class="form-control" style="min-height:320px;font-family:monospace;font-size:.82rem;"></textarea>
                        <span asp-validation-for="Content" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">SEO</div>
                <div class="card-body">
                    <div class="form-group">
                        <label asp-for="MetaTitle"></label>
                        <input asp-for="MetaTitle" class="form-control" />
                        <span asp-validation-for="MetaTitle" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="MetaDescription"></label>
                        <textarea asp-for="MetaDescription" class="form-control" style="min-height:80px;"></textarea>
                        <span asp-validation-for="MetaDescription" class="field-validation-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="card" style="margin-bottom:1.25rem;">
                <div class="card-header">Publish</div>
                <div class="card-body">
                    <div class="form-group">
                        <label asp-for="Status"></label>
                        <select asp-for="Status" class="form-control"
                            asp-items="Html.GetEnumSelectList<CornerstoneZearing.PageStatus>()"></select>
                        <span asp-validation-for="Status" class="field-validation-error"></span>
                    </div>
                    <div class="form-actions" style="margin-top:.75rem;">
                        <button type="submit" class="btn btn-primary" style="width:100%;">
                            <i class="fas fa-floppy-disk"></i> @(isEdit ? "Save Changes" : "Save Page")
                        </button>
                    </div>
                </div>
            </div>

            <div class="card" style="margin-bottom:1.25rem;">
                <div class="card-header">URL</div>
                <div class="card-body">
                    <div class="form-group" style="margin-bottom:0;">
                        <label asp-for="UrlSlug"></label>
                        <div style="display:flex;align-items:center;gap:.4rem;">
                            <span style="color:#64748b;font-size:.875rem;">/</span>
                            <input asp-for="UrlSlug" class="form-control" id="urlSlug" />
                        </div>
                        <span asp-validation-for="UrlSlug" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">Template</div>
                <div class="card-body">
                    <div class="form-group" style="margin-bottom:0;">
                        <label asp-for="TemplateName"></label>
                        <input asp-for="TemplateName" class="form-control" />
                        <span asp-validation-for="TemplateName" class="field-validation-error"></span>
                        <span class="text-muted" style="font-size:.75rem;display:block;margin-top:.35rem;">
                            Razor file in Views/Templates/ (without .cshtml)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (!isEdit)
    {
        <script>
            const nameInput = document.getElementById('pageName');
            const slugInput = document.getElementById('urlSlug');
            let slugEdited = false;

            slugInput.addEventListener('input', () => { slugEdited = true; });

            nameInput.addEventListener('input', () => {
                if (slugEdited) return;
                slugInput.value = nameInput.value
                    .toLowerCase()
                    .trim()
                    .replace(/[^a-z0-9\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-');
            });
        </script>
    }
}
