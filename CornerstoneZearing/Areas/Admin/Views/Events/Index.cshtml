@model IEnumerable<CornerstoneZearing.Data.Event>
@using CornerstoneZearing.Data
@{
	ViewData["Section"] = "Events";
	ViewData["Title"] = "Events";
}

<div class="page-header">
	<h1>Events</h1>
	<a asp-action="Create" class="btn btn-primary">
		<i class="fas fa-plus"></i> Add Event
	</a>
</div>

<div class="card">
	<div class="table-wrapper">
		<table>
			<thead>
				<tr>
					<th style="width: 30%;">Event</th>
					<th style="width: 20%;">Location</th>
					<th style="width: 25%;">Start</th>
					<th style="width: 25%;">End</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var evnt in Model)
				{
					var start = evnt.StartDateTime.ToLocalTime();
					var end = evnt.EndDateTime.ToLocalTime();
					<tr>
						<td>
							<strong>@evnt.Name</strong>
							@if (evnt.IsAllDay)
							{
								<span class="badge badge-secondary" style="margin-left:.4rem;">All Day</span>
							}
							@{
								var recurrenceSummary = CornerstoneZearing.Areas.Admin.Helpers.EventHelper.RecurrenceSummary(evnt);
								if (!string.IsNullOrEmpty(recurrenceSummary))
								{
									<i class="fa-solid fa-repeat text-muted" title="@recurrenceSummary"></i>
								}
							}
							@if (evnt.IsPrivate)
							{
								<i class="fa-solid fa-eye-slash " title="Private Event"></i>
							}
						</td>
						<td class="text-muted">
							@evnt.Location
						</td>
						<td>
							@(evnt.IsAllDay ? start.ToString("MMM d, yyyy") : start.ToString("MMM d, yyyy h:mm tt"))
						</td>
						<td>
							@(evnt.IsAllDay ? "" : end.ToString("MMM d, yyyy h:mm tt"))
						</td>
						<td>
							<div class="action-buttons">
								<a asp-action="Edit" asp-route-id="@evnt.EventID" class="btn btn-secondary btn-sm">
									<i class="fas fa-pen"></i> Edit
								</a>
								<a asp-action="Delete" asp-route-id="@evnt.EventID" class="btn btn-danger btn-sm">
									<i class="fas fa-trash"></i>
								</a>
							</div>
						</td>
					</tr>
				}
				@if (!Model.Any())
				{
					<tr>
						<td colspan="7" style="text-align:center;color:#64748b;padding:2rem;">
							No events found. <a asp-action="Create" style="color:var(--primary);">Add the first event.</a>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>